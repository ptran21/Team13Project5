    {
      "name": "04 Register User",
      "event": [
        {
          "listen": "prerequest",
          "script": {
            "type": "text/javascript",
            "exec": [
              "const runId = Date.now();",
              "pm.collectionVariables.set('username', `user_${runId}`);",
              "pm.collectionVariables.set('email', `user_${runId}@example.com`);",
              "pm.collectionVariables.set('password', 'Password123!');"
            ]
          }
        },
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Register returns 201', function () {",
              "  pm.response.to.have.status(201);",
              "});",
              "",
              "const body = pm.response.json();",
              "pm.test('Register response includes token', function () {",
              "  pm.expect(body.token).to.be.a('string');",
              "});",
              "",
              "if (body.token) {",
              "  pm.collectionVariables.set('authToken', body.token);",
              "}"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"username\": \"{{username}}\",\n  \"email\": \"{{email}}\",\n  \"password\": \"{{password}}\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/auth/register",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "auth",
            "register"
          ]
        }
      },
      "response": []
    },
