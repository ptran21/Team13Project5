          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Categories endpoint returns 200', function () {",
              "  pm.response.to.have.status(200);",
              "});",
              "",
              "const body = pm.response.json();",
              "pm.test('Categories is an array', function () {",
              "  pm.expect(body.categories).to.be.an('array');",
              "});",
              "",
              "if (body.categories.length > 0) {",
              "  pm.collectionVariables.set('categoryId', body.categories[0].id);",
              "}"
            ]
          }
        }
