    {
      "name": "06 Create Listing (Registered User)",
      "event": [
        {
          "listen": "prerequest",
          "script": {
            "type": "text/javascript",
            "exec": [
              "const categoryId = pm.collectionVariables.get('categoryId') || 1;",
              "pm.collectionVariables.set('categoryId', categoryId);",
              "pm.collectionVariables.set('listingTitle', `Postman Test Listing ${Date.now()}`);"
            ]
          }
        },
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Create listing returns 201', function () {",
              "  pm.response.to.have.status(201);",
              "});",
              "",
              "const body = pm.response.json();",
              "pm.test('Create listing response includes listing_id', function () {",
              "  pm.expect(body.listing_id).to.be.a('number');",
              "});",
              "",
              "if (body.listing_id) {",
              "  pm.collectionVariables.set('lastCreatedListingId', body.listing_id);",
              "}"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{authToken}}"
          },
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"title\": \"{{listingTitle}}\",\n  \"category_id\": {{categoryId}},\n  \"price\": 123.45,\n  \"description\": \"Listing created by Postman API test run.\",\n  \"city\": \"Ames\",\n  \"phone\": \"515-222-3333\",\n  \"condition_status\": \"Used\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/listings",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "listings"
          ]
        }
      },
